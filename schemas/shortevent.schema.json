    "ShortEventSchemaItem": {
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "description": "Unique string used to identify the event.",
          "title": "Event Id",
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/Location",
          "description": "Controls the biome and camp the event appears in."
        },
        "season": {
          "description": "List of seasons in which the event may occur.",
          "items": {
            "$ref": "#/$defs/Season"
          },
          "title": "Season",
          "type": "array"
        },
        "sub_type": {
          "description": "List of sub_types for this event.",
          "items": {
            "$ref": "#/$defs/EventSubtype"
          },
          "title": "Sub Type",
          "type": "array"
        },
        "tags": {
          "description": "Used for some filtering purposes",
          "items": {
            "$ref": "#/$defs/Tag"
          },
          "title": "Tags",
          "type": "array"
        },
        "poi": {
          "$ref": "#/$defs/PointsOfInterestGroup",
          "description": "The relevant points of interest. Points of Interest never affect outcome.",
          "title": "Poi"
        },
        "frequency": {
          "description": "Controls how common an event is. 4 == Common, 3 == Uncommon, 2 == Rare, 3 == Very Rare. Consider this in the terms of 'If an event of this type happened every moon for 10 moons, on how many of those moons should this sort of event appear?'",
          "title": "Frequency",
          "type": "integer"
        },
        "event_text": {
          "description": "Text that appears within the event list when the event occurs.",
          "title": "Event Text",
          "type": "string"
        },
        "new_accessory": {
          "description": "If the event gives a new accessory, list possible new accessories here (one will be chosen from the list)",
          "items": {
            "type": "string"
          },
          "title": "New Accessory",
          "type": "array"
        },
        "m_c": {
          "$ref": "#/$defs/MC",
          "description": "Specifies the requirements for the main cat (m_c) of the event.",
          "title": "M C"
        },
        "r_c": {
          "$ref": "#/$defs/RC",
          "description": "Specifies the requirements for the random cat (r_c) of the event.",
          "title": "R C"
        },
        "new_cat": {
          "description": "Adds a new cat.",
          "items": {
            "$ref": "#/$defs/NewCat"
          },
          "title": "New Cat",
          "type": "array"
        },
        "injury": {
          "description": "Indicates which cats get injured, and how.",
          "items": {
            "$ref": "#/$defs/InjuryItem"
          },
          "title": "Injury",
          "type": "array"
        },
        "history": {
          "description": "Controls the history-text for scars and death.",
          "items": {
            "$ref": "#/$defs/HistoryText"
          },
          "title": "History",
          "type": "array"
        },
        "relationships": {
          "description": "Indicates effect on cat relationships.",
          "items": {
            "$ref": "#/$defs/Relationship"
          },
          "title": "Relationships",
          "type": "array"
        },
        "exclude_involved": {
          "description": "Excludes certain cats from showing up in the \"involved cats\" list of the event, meaning their button will not be present on the events screen.",
          "items": {
            "$ref": "#/$defs/Cat"
          },
          "title": "Exclude Involved",
          "type": "array"
        },
        "new_gender": {
          "description": "New gender for cats who are transitioning.",
          "items": {
            "$ref": "#/$defs/NewGenderEnum"
          },
          "title": "New Gender",
          "type": "array"
        },
        "future_event": {
          "description": "Schedules another event to happen in the future.",
          "items": {
            "$ref": "#/$defs/FutureEvent"
          },
          "title": "Future Event",
          "type": "array"
        },
        "outsider": {
          "$ref": "#/$defs/Outsider",
          "description": "Dictates what reputation the clan is required to have with outsiders as well as how that reputation changes due to the event."
        },
        "other_clan": {
          "$ref": "#/$defs/OtherClan",
          "description": "Dictates what reputation the clan is required to have with the other clan as well as how that reputation changes due to the event.",
          "title": "Other Clan"
        },
        "supplies": {
          "description": "Dictates how this event changes the various supply pools of the clan.",
          "items": {
            "$ref": "#/$defs/Supply"
          },
          "title": "Supplies",
          "type": "array"
        }
      },
      "required": [
        "event_id",
        "location",
        "season",
        "frequency",
        "event_text"
      ],
      "title": "ShortEventSchemaItem",
      "type": "object"
