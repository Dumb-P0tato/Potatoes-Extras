{
  "$defs": {
    "Age": {
      "enum": [
        "newborn",
        "-newborn",
        "kitten",
        "-kitten",
        "adolescent",
        "-adolescent",
        "young adult",
        "-young adult",
        "adult",
        "-adult",
        "senior adult",
        "-senior adult",
        "senior",
        "-senior"
      ],
      "title": "Age",
      "type": "string"
    },
    "AllTrait": {
      "anyOf": [
        {
          "$ref": "#/$defs/Trait"
        },
        {
          "$ref": "#/$defs/KitTrait"
        }
      ],
      "title": "AllTrait"
    },
    "Biome": {
      "enum": [
        "mountainous",
        "-mountainous",
        "plains",
        "-plains",
        "forest",
        "-forest",
        "beach",
        "-beach",
        "wetlands",
        "-wetlands",
        "desert",
        "-desert"
      ],
      "title": "Biome",
      "type": "string"
    },
    "CanHaveStat": {
      "enum": [
        "p_l",
        "r_c",
        "app1",
        "app2",
        "not_pl",
        "not_rc",
        "not_pl_rc",
        "any",
        "adult",
        "app",
        "healer"
      ],
      "title": "CanHaveStat",
      "type": "string"
    },
    "Cat": {
      "anyOf": [
        {
          "$ref": "#/$defs/CatEnum"
        },
        {
          "pattern": "^n_c:[0-9]+$",
          "type": "string"
        }
      ],
      "title": "Cat"
    },
    "CatEnum": {
      "enum": [
        "m_c",
        "r_c"
      ],
      "title": "CatEnum",
      "type": "string"
    },
    "EventSubtype": {
      "enum": [
        "war",
        "murder",
        "old_age",
        "mass_death",
        "murder_reveal",
        "hidden_murder_reveal",
        "failed_murder",
        "accessory",
        "ceremony",
        "transition",
        "mediator"
      ],
      "title": "EventSubtype",
      "type": "string"
    },
    "EventType": {
      "enum": [
        "death",
        "injury",
        "new_cat",
        "misc"
      ],
      "title": "EventType",
      "type": "string"
    },
    "FutureCat": {
      "additionalProperties": false,
      "properties": {
        "age": {
          "description": "List of ages the cat can be. If they can be anything, use \"any\".",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/Age"
              },
              {
                "const": "any",
                "type": "string"
              }
            ]
          },
          "title": "Age",
          "type": "array"
        },
        "status": {
          "description": "List of statuses the cat can be. If they can be anything, use \"any\".",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/Status"
              },
              {
                "const": "any",
                "type": "string"
              }
            ]
          },
          "title": "Status",
          "type": "array"
        },
        "skill": {
          "description": "The cat must possess at least one skill from this list. If they can be anything, use \"any\".",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/Skill"
              },
              {
                "const": "any",
                "type": "string"
              }
            ]
          },
          "title": "Skill",
          "type": "array"
        },
        "trait": {
          "description": "The cat must possess at least one trait from this list. If they can be anything, use \"any\".",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/AllTrait"
              },
              {
                "const": "any",
                "type": "string"
              }
            ]
          },
          "title": "Trait",
          "type": "array"
        },
        "gender": {
          "description": "The cat will have this gender.",
          "items": {
            "$ref": "#/$defs/GenderEnum"
          },
          "title": "Gender",
          "type": "array"
        }
      },
      "title": "FutureCat",
      "type": "object"
    },
    "FutureEvent": {
      "additionalProperties": false,
      "properties": {
        "event_type": {
          "$ref": "#/$defs/EventType",
          "description": "Specify which ShortEvent type the future event will be."
        },
        "moon_delay": {
          "description": "How many moons must pass before the first event appears (inclusive). The first value is the smallest possible delay and the second value is the largest.",
          "maxItems": 2,
          "minItems": 2,
          "prefixItems": [
            {
              "type": "integer"
            },
            {
              "type": "integer"
            }
          ],
          "title": "Moon Delay",
          "type": "array"
        },
        "pool": {
          "$ref": "#/$defs/FutureEventPool",
          "description": "Pool of events to be chosen from. Only one event from the pool will be chosen."
        },
        "involved_cats": {
          "$ref": "#/$defs/FutureEventInvolvedCats",
          "description": "Specifies which cats can fill the roles within the future event."
        }
      },
      "required": [
        "event_type",
        "moon_delay",
        "pool",
        "involved_cats"
      ],
      "title": "FutureEvent",
      "type": "object"
    },
    "FutureEventInvolvedCats": {
      "additionalProperties": false,
      "properties": {
        "m_c": {
          "anyOf": [
            {
              "$ref": "#/$defs/FutureCat"
            },
            {
              "$ref": "#/$defs/Cat"
            }
          ],
          "description": "m_c in the future event. Can either be a cat in the current event or constraints for a newly chosen cat.",
          "title": "Main Cat"
        },
        "mur_c": {
          "anyOf": [
            {
              "$ref": "#/$defs/FutureCat"
            },
            {
              "$ref": "#/$defs/Cat"
            }
          ],
          "description": "The murdered cat in the future event. Can either be a cat in the current event or constraints for a newly chosen cat.",
          "title": "Murdered Cat"
        },
        "r_c": {
          "anyOf": [
            {
              "$ref": "#/$defs/FutureCat"
            },
            {
              "$ref": "#/$defs/Cat"
            }
          ],
          "description": "r_c in the future event. Can either be a cat in the current event or constraints for a newly chosen cat.",
          "title": "Random Cat"
        }
      },
      "title": "FutureEventInvolvedCats",
      "type": "object"
    },
    "FutureEventPool": {
      "additionalProperties": false,
      "properties": {
        "sub_type": {
          "description": "Events to be added to the pool will contain all subtypes specified.",
          "items": {
            "$ref": "#/$defs/EventSubtype"
          },
          "title": "Sub Type",
          "type": "array"
        },
        "event_id": {
          "description": "Only events with the specified event_ids will be added to the pool.",
          "items": {
            "type": "string"
          },
          "title": "Event Id",
          "type": "array"
        },
        "excluded_event_id": {
          "description": "All events with the specified event_ids will be removed from the pool.",
          "items": {
            "type": "string"
          },
          "title": "Excluded Event Id",
          "type": "array"
        }
      },
      "title": "FutureEventPool",
      "type": "object"
    },
    "GatherCat": {
      "anyOf": [
        {
          "$ref": "#/$defs/GatherCatEnum"
        },
        {
          "pattern": "^-?n_c:[0-9]+$",
          "type": "string"
        }
      ],
      "title": "GatherCat"
    },
    "GatherCatEnum": {
      "enum": [
        "m_c",
        "-m_c",
        "r_c",
        "-r_c",
        "p_l",
        "-p_l",
        "s_c",
        "-s_c",
        "app1",
        "-app1",
        "app2",
        "-app2",
        "app3",
        "-app3",
        "app4",
        "-app4",
        "app5",
        "-app5",
        "app6",
        "-app6",
        "clan",
        "-clan",
        "some_clan",
        "-some_clan",
        "patrol",
        "-patrol",
        "multi",
        "-multi",
        "high_lawful",
        "-high_lawful",
        "low_lawful",
        "-low_lawful",
        "high_social",
        "-high_social",
        "low_social",
        "-low_social",
        "high_stable",
        "-high_stable",
        "low_stable",
        "-low_stable",
        "high_aggress",
        "-high_aggress",
        "low_aggress",
        "-low_aggress"
